{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "vuex": ["./node_modules/vuex/types/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "src/vite-env.d.ts"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
